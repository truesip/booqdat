{
  "name": "booqdat-platform",
  "version": "1.0.0",
  "private": true,
  "description": "BOOQDAT event ticketing platform",
  "type": "commonjs",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check:syntax": "node --check server.js && node --check src/app.js && node --check src/routes/api.js && node --check src/config/env.js && node --check assets/app.js && node --check assets/auth-runtime.js && node --check assets/auth-guard.js",
    "test": "node --test test/**/*.test.js",
    "test:auth": "node --test test/auth.integration.test.js",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test test/e2e/auth-login.spec.js",
    "test:e2e:install": "playwright install chromium",
    "verify": "npm run check:syntax && npm run test:auth"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "mongodb-memory-server": "^10.2.3",
    "nodemon": "^3.1.4",
    "supertest": "^7.1.4"
  }
}
