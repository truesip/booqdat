NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=12mb
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=30d
NYVAPAY_BASE_URL=https://nyvapay.com
NYVAPAY_MERCHANT_EMAIL=replace-with-nyvapay-merchant-email
NYVAPAY_API_KEY=replace-with-nyvapay-api-key
NYVAPAY_WEBHOOK_URL=
NYVAPAY_SUCCESS_REDIRECT_URL=
NYVAPAY_WEBHOOK_TOKEN=optional-random-webhook-token
NYVAPAY_TIMEOUT_MS=8000
NYVAPAY_MAX_ATTEMPTS=2
SMTP2GO_API_BASE_URL=https://api.smtp2go.com/v3
SMTP2GO_API_KEY=replace-with-smtp2go-api-key
SENDER_DOMAIN=booqdat.com
MAIL_FROM=no-reply@booqdat.com
MAIL_FROM_NAME=BOOQDAT
MAIL_REPLY_TO=helloworld@booqdat.com
SUPPORT_EMAIL=helloworld@booqdat.com
COMPANY_NAME=BOOQDAT
SEED_ADMIN_EMAIL=admin@booqdat.com
SEED_ADMIN_PASSWORD=change-this-admin-password
